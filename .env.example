# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Service role key — обходит RLS, используется ТОЛЬКО на сервере (вебхуки, фоновые задачи)
# Взять: Supabase Dashboard → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Site URL (для редиректов после авторизации)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# DeepSeek AI (для генерации ТЗ)
DEEPSEEK_API_KEY=your_deepseek_api_key

# Session cookie lifetime in days (default: 7)
# SESSION_COOKIE_MAX_AGE_DAYS=7

# YooKassa (для приема оплат)
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key
YOOKASSA_RETURN_URL=http://localhost:3000/api/yookassa/return
